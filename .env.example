# ─────────────────────────────────────────────────────────────
# Copia este archivo a ".env" y rellena tus claves.
# NUNCA subas el archivo .env real al repositorio (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Clave de API-Football (https://www.api-sports.io/ -> dashboard)
# Se envía en el header x-apisports-key.
APISPORTS_KEY=tu_clave_api_football_aqui

# Clave de Google Gemini (https://aistudio.google.com/apikey)
# Solo necesaria para la capa de agente (src/agent). El tier gratuito cubre los
# modelos Flash / Flash-Lite (los Pro son de pago).
GEMINI_API_KEY=tu_clave_gemini_aqui
# (Opcional) modelo Gemini a usar; por defecto gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# ── Bot de Telegram (capa de producto / suscripción) ──────────────────
# Token del bot, obtenido de @BotFather en Telegram. Necesario para `python
# main.py bot`. NO lo subas al repo.
TELEGRAM_BOT_TOKEN=tu_token_de_botfather_aqui
# (Opcional) Tu ID numérico de Telegram para comandos admin (p.ej. /grant).
# ADMIN_TELEGRAM_ID=123456789

# ── Cuotas históricas para el ROI REAL del backtest (Parte ROI) ───────
# Opción A: coloca un CSV en data/odds.csv (ver README).
# Opción B: clave de una API de cuotas. Vale para OddsPapi (oddspapi.io) o The
# Odds API. Con `python main.py fetch-odds` se vuelca a data/odds.csv.
# ODDS_API_KEY=tu_clave_de_cuotas_aqui
# Proveedor: oddspapi | the_odds_api | auto (auto = oddspapi).
# ODDS_PROVIDER=oddspapi
# NOTA OddsPapi: cubre internacionales (World Cup, eliminatorias, Euro...), pero
# su histórico de cuotas empieza ~enero 2026 (no hay 2018/2022). Tier free: 250/mes.

# ── Parámetros opcionales (si se omiten se usan los defaults de config.py) ──
# Override de temporada para el plan GRATUITO de API-Football (solo 2022–2024).
# Pon TEMPORADA=2022 para probar el producto con el Mundial 2022.
# TEMPORADA=2022
# BANKROLL_INICIAL=1000
# OBJETIVO_GANANCIA=500
# UMBRAL_VALOR=0.05
# KELLY_FRACCION=0.25
# STAKE_MAX_PCT=0.05
# MAX_LEGS=3

# ── Ratings internacionales (Parte A) ──
# Vida media del decaimiento temporal (días) y nº de iteraciones del ajuste.
# RATINGS_HALF_LIFE_DIAS=1460
# RATINGS_ITERACIONES=50

# ── Suscripción / scheduler (Parte B) ──
# SUSCRIPCION_DIAS=30
# PUBLICAR_HORA=9
# PUBLICAR_MINUTO=0
# LIQUIDAR_CADA_MIN=60
# MAX_RECS_PUBLICADAS=5
